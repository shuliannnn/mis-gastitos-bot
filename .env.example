# Número autorizado para enviar comandos (formato completo con @s.whatsapp.net)
# Ejemplo: 5491112345678@s.whatsapp.net
AUTHORIZED_NUMBER=5491112345678@s.whatsapp.net

# ID del Google Sheet (lo encontrás en la URL: docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit)
SHEET_ID=tu_sheet_id_aqui

# Ruta al archivo credentials.json de la Service Account
CREDENTIALS_PATH=./credentials.json
